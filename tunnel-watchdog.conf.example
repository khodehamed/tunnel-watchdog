# Tunnel Watchdog config
# Format: name|systemd_unit|check_type|check_arg
#
# Recommended (Backhaul/Backpack clients):
#   control_channel|REMOTE_PORT:HEALTHY_MIN_ESTAB
#   e.g. 8080:4
#
# Health rules (control_channel):
#   - Recent "control channel established" → OK
#   - If toml has tun_name and iface is missing and there is NO recent success
#     → FAIL (zombie Cloudflare ESTAB alone is not enough)
#   - Else need ESTAB >= HEALTHY_MIN (default 4) AND at least one fresh socket
#   - 1–2 leftover zombie sockets must NOT count as healthy
#
# Safety knobs:
FAIL_THRESHOLD=5
COOLDOWN_SEC=300
GRACE_SEC=300
JOURNAL_LOOKBACK=15min
CONTROL_JOURNAL_SINCE="5 min ago"

TUNNELS="
# backhaul-example|backhaul-kharej8080.service|control_channel|8080:4
# backpack-example|backpack-client-2082.service|control_channel|2082:4
"
