# Tunnel Watchdog config
# Format: name|systemd_unit|check_type|check_arg
#
# Recommended (Backhaul/Backpack clients):
#   control_channel|REMOTE_PORT:DEAD_BELOW
#   e.g. 8080:2
#
# FAIL only when ESTAB < DEAD_BELOW (and no recent "control channel established").
# Transient bad-handshake while sockets remain does NOT force restart.
#
# Safety knobs:
FAIL_THRESHOLD=5
COOLDOWN_SEC=300
GRACE_SEC=300
JOURNAL_LOOKBACK=15min
CONTROL_JOURNAL_SINCE="3 min ago"

TUNNELS="
# backhaul-example|backhaul-kharej8080.service|control_channel|8080:2
# backpack-example|backpack-client-2082.service|control_channel|2082:2
"
